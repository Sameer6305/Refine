# ── Required for backend API ──────────────────────────────────────────────── #
# Gemini API key — used once at setup time to parse the JD. Not called during
# the ranking run itself (result is cached in precomputed/parsed_jd.json).
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — free alternative to Gemini for JD parsing (30 req/min, 500K tokens/day, no credit card)
# Sign up at https://console.groq.com and get a free API key.
# When GROQ_API_KEY is set it takes priority over GEMINI_API_KEY (faster, no quota issues).
GROQ_API_KEY=your_groq_api_key_here

# JWT secret — change to a long random string in production.
SECRET_KEY=your_jwt_secret_here_change_in_production

# ── Database ──────────────────────────────────────────────────────────────── #
# SQLite (default, no setup needed) or PostgreSQL for production.
DATABASE_URL=sqlite:///./sql_app.db

# ── Ranking system paths ──────────────────────────────────────────────────── #
# Pre-computed candidate embeddings produced by precompute_embeddings.py.
# If these files are absent, the backend falls back to on-the-fly embedding.
EMBEDDINGS_PATH=./precomputed/embeddings.npy
CANDIDATE_IDS_PATH=./precomputed/candidate_ids.json
CANDIDATES_JSONL_PATH=./candidates.jsonl
PARSED_JD_CACHE_PATH=./precomputed/parsed_jd.json
RICH_REASONING_PATH=./precomputed/rich_reasoning.json
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Logging ───────────────────────────────────────────────────────────────── #
LOG_LEVEL=INFO

# ── CORS (comma-separated origins, or * for open access in dev) ───────────── #
ALLOWED_ORIGINS=*
